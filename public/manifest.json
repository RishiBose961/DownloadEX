{
  "manifest_version": 3,
  "name": "DownloadEx",
  "version": "1.0",
  "permissions": ["downloads", "activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16": "download.png",
    "32": "download.png",
    "48": "download.png",
    "128":"download.png"
  },

  "action": {
    "default_icon": {
      "16": "download.png",
      "32": "download.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}